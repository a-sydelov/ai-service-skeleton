LOG_LEVEL=INFO
SERVICE_NAME=inference-service
SERVICE_VERSION=0.1.0

GATEWAY_PORT=8080
V1_URL=http://inference-v1:8000
V2_URL=http://inference-v2:8000
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
ALERTMANAGER_PORT=9093

V1_REPLICAS=2
V2_REPLICAS=1

MODEL_NAME=model
MODEL_DIR_V1=/models/model/1
MODEL_DIR_V2=/models/model/2

RELOAD_TOKEN=dev-reload-token
ADMIN_TOKEN=dev-admin-token

PRIMARY_VARIANT=v1
SHADOW_VARIANT=v2
SHADOW_SAMPLE_RATE=0.10
SERVE_SHADOW_RATE=0.0


INFERENCE_CPUS=1.0
INFERENCE_MEM=768m
ROUTER_CPUS=1.0
ROUTER_MEM=768m

DATA_ROOT=data

# Extra thresholds / safety limits
MAX_REQUEST_BYTES=1000000
MAX_BATCH_SIZE=256

# Inference hot-path tuning
METRICS_PROFILE=lean
CLASSIFICATION_INCLUDE_PROBA=false
EMBEDDING_INCLUDE_VECTOR=true
